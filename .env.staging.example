APP_NAME=capitec-financial-insights-api
APP_ENV=staging
DATABASE_URL=postgresql+psycopg://<user>:<password>@<managed-postgres-host>:5432/<database>
REDIS_URL=redis://<managed-cache-host>:6379/0
MINIO_ENDPOINT=<managed-object-storage-endpoint>
MINIO_PORT=443
MINIO_ACCESS_KEY=<staging-access-key>
MINIO_SECRET_KEY=<staging-secret-key>
MINIO_BUCKET=bank-statements-staging
MINIO_USE_SSL=true
