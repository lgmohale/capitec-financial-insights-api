APP_NAME=capitec-financial-insights-api
APP_ENV=production
DATABASE_URL=postgresql+psycopg://<user>:<password>@<managed-postgres-host>:5432/<database>
REDIS_URL=rediss://<managed-cache-host>:6379/0
MINIO_ENDPOINT=<managed-object-storage-endpoint>
MINIO_PORT=443
MINIO_ACCESS_KEY=<production-access-key>
MINIO_SECRET_KEY=<production-secret-key>
MINIO_BUCKET=bank-statements-production
MINIO_USE_SSL=true
